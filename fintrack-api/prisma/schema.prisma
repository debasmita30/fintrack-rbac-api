// This is your Prisma schema file
// SQLite used for zero-infrastructure local development
// To switch to PostgreSQL: change provider to "postgresql" and update DATABASE_URL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  password  String
  role      String   @default("VIEWER") // VIEWER | ANALYST | ADMIN
  status    String   @default("ACTIVE") // ACTIVE | INACTIVE
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions  Transaction[]
  auditLogs     AuditLog[]
  refreshTokens RefreshToken[]

  @@map("users")
}

model Transaction {
  id          String   @id @default(uuid())
  amount      Float
  type        String   // INCOME | EXPENSE
  category    String
  date        DateTime
  description String?
  notes       String?
  tags        String   @default("[]") // JSON array stored as string for SQLite
  isDeleted   Boolean  @default(false)
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy   User   @relation(fields: [createdById], references: [id])
  createdById String

  auditLogs AuditLog[]

  @@map("transactions")
}

model AuditLog {
  id            String   @id @default(uuid())
  action        String   // CREATE | UPDATE | DELETE | RESTORE | LOGIN | LOGOUT
  entity        String   // User | Transaction
  entityId      String
  oldData       String?  // JSON string
  newData       String?  // JSON string
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime @default(now())

  performedBy   User   @relation(fields: [performedById], references: [id])
  performedById String

  transaction   Transaction? @relation(fields: [entityId], references: [id])

  @@map("audit_logs")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  expiresAt DateTime
  isRevoked Boolean  @default(false)
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  userId String

  @@map("refresh_tokens")
}
